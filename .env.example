# CodeReviewer environment configuration
#
# Copy to `.env` (gitignored) and fill in what you need. Precedence is:
#   built-in defaults < .codereviewer/config.json < process env < .env < CLI flags
# Every value here is OPTIONAL; the engine runs with built-in defaults.
# Secrets are never written to logs, traces, or reports.

# --- Review scope ---------------------------------------------------------
# mode: local | ci | pr | full   depth: fast | balanced | thorough
CODEREVIEWER_REVIEW_MODE=local
CODEREVIEWER_REVIEW_DEPTH=balanced
CODEREVIEWER_BASE_REF=main
CODEREVIEWER_HEAD_REF=HEAD

# --- Provider (required only for model-backed review) ---------------------
# id: openai | openai-compatible | bedrock | azure
CODEREVIEWER_PROVIDER_ID=
CODEREVIEWER_PROVIDER_MODEL=
# baseUrl is required for openai-compatible providers.
CODEREVIEWER_PROVIDER_BASE_URL=
# Reasoning effort for reasoning models (OpenAI Responses API):
# minimal | low | medium | high. Leave empty to use the provider default.
# Note: high reasoning is NOT recommended — in testing it raised cost/latency
# substantially without improving recall.
CODEREVIEWER_PROVIDER_REASONING_EFFORT=

# --- AI review (agentic proof loop) ---------------------------------------
# intentPlanning: auto | deterministic | model
CODEREVIEWER_AI_INTENT_PLANNING=auto
# deterministicSignalMode: support (inject facts as model context; better recall)
#                          | disabled (keep clustering, skip injection; cheaper)
CODEREVIEWER_AI_DETERMINISTIC_SIGNAL_MODE=support
# Optional strict critic pass for proved findings (extra cost; default off).
CODEREVIEWER_AI_JUDGE_FINDINGS=false

# --- Paths ----------------------------------------------------------------
CODEREVIEWER_CONFIG_PATH=.codereviewer/config.json
CODEREVIEWER_ARTIFACT_DIR=.codereviewer/runs
CODEREVIEWER_SKILLS_DIR=.codereviewer/skills

# --- Observability --------------------------------------------------------
# level: trace | debug | info | warn | error | fatal | silent
CODEREVIEWER_LOG_LEVEL=silent
CODEREVIEWER_OPENTELEMETRY_ENABLED=false
CODEREVIEWER_OPENTELEMETRY_ENDPOINT=
CODEREVIEWER_OPENTELEMETRY_HEADERS=

# --- Cost tracking (optional pricing overrides) ---------------------------
CODEREVIEWER_COST_INPUT_PER_MILLION=
CODEREVIEWER_COST_OUTPUT_PER_MILLION=

# --- Provider credentials -------------------------------------------------
# OpenAI and OpenAI-compatible providers
OPENAI_API_KEY=

# AWS Bedrock
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure
AZURE_AI_ENDPOINT=
AZURE_AI_API_KEY=
