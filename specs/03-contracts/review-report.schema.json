              },
              "incompleteReason": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              }
            },
            "required": [
              "path",
              "contentHash",
              "status",
              "bytes",
              "coveredBytes",
              "taskIds"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "status",
        "reviewableFileCount",
        "coveredFileCount",
        "reviewableBytes",
        "coveredBytes",
        "incompleteReasons",
        "files"
      ],
      "additionalProperties": false
