                      }
                    },
                    "required": [
                      "id",
                      "location",
                      "message"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "id",
                "label",
                "steps"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "kind",
          "summary",
          "source",
          "redactionApplied"
        ],
        "additionalProperties": false
      }
    },
    "skippedFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "enum": [
              "deleted",
              "binary",
              "too-large",
              "too-many-files",
              "excluded",
              "unsupported",
              "error"
            ]
          },
          "message": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "path",
          "reason"
        ],
        "additionalProperties": false
      }
    },
    "qualityGate": {
      "type": "object",
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "failingFindingIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?:test-[A-Za-z0-9_-]+|[a-z]+(?:_[a-z0-9]+)+)$"
          }
        },
        "thresholds": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "baselineFilteringApplied": {
          "type": "boolean"
        }
      },
      "required": [
        "passed",
        "failingFindingIds",
        "thresholds"
      ],
      "additionalProperties": false
    },
    "refutationResults": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?:test-[A-Za-z0-9_-]+|[a-z]+(?:_[a-z0-9]+)+)$"
          },
          "candidateId": {
            "type": "string",
            "pattern": "^(?:test-[A-Za-z0-9_-]+|cand_[a-z0-9]+(?:_[a-z0-9]+)*)$"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "proved",
              "refuted",
              "needs-more-evidence",
              "provider-error"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "evidenceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(?:test-[A-Za-z0-9_-]+|[a-z]+(?:_[a-z0-9]+)+)$"
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "result": {
                  "type": "string",
                  "enum": [
                    "passed",
                    "failed",
                    "unknown"
                  ]
                },
                "summary": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 500
                },
                "evidenceIds": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^(?:test-[A-Za-z0-9_-]+|[a-z]+(?:_[a-z0-9]+)+)$"
                  }
                }
              },
              "required": [
                "kind",
                "result",
                "summary",
                "evidenceIds"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "candidateId",
          "verdict",
          "summary",
          "evidenceIds",
          "checks"
        ],
        "additionalProperties": false
      }
    },
    "providerIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "stage": {
            "type": "string",
            "minLength": 1
          },
          "recovered": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "required": [
          "code"
        ],
        "additionalProperties": false
      }
    },
    "resolvedBaselineEntries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "pattern": "^[a-z0-9]+$"
          }
        },
        "required": [
          "algorithm",
          "value"
        ],
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "enum": [
              "json",
              "markdown",
              "sarif",
              "github-review-comments"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "containsSensitiveContent": {
            "type": "boolean",
            "const": false
          }
        },
        "required": [
          "format",
          "path",
          "sha256",
          "containsSensitiveContent"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "run",
    "coverage",
    "admittedFindings",
    "rejectedFindings",
    "evidence",
    "skippedFiles",
    "refutationResults",
    "providerIssues",
    "artifacts"
  ],
  "additionalProperties": false,
  "$id": "https://codereviewer.local/schemas/review-report.schema.json",
  "title": "ReviewReport"
}
