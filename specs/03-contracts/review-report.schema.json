{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "run": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "mode": {
          "type": "string",
          "enum": [
            "local",
            "ci",
            "pr",
            "full"
          ]
        },
        "depth": {
          "type": "string",
          "enum": [
            "fast",
            "balanced",
            "thorough"
          ]
        },
        "repositoryRootHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "baseRef": {
          "type": "string"
        },
        "headRef": {
          "type": "string"
        },
        "configHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "costUsd": {
          "type": "number",
          "minimum": 0
        },
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "runId",
        "startedAt",
        "completedAt",
        "mode",
        "depth",
        "repositoryRootHash",
        "configHash",
        "durationMs",
        "warnings"
      ],
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete"
