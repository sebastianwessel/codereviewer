            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "contentHash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "complete",
                  "incomplete"
