        "baseRef": {
          "default": "main",
          "type": "string",
          "minLength": 1
        },
        "headRef": {
          "default": "HEAD",
          "type": "string",
          "minLength": 1
        },
        "maxConcurrentTasks": {
          "default": 4,
          "type": "integer",
          "minimum": 1,
          "maximum": 32
