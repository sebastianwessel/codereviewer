        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "reasoningEffort": {
          "type": "string",
          "enum": [
            "minimal",
            "low",
            "medium",
            "high"
          ]
