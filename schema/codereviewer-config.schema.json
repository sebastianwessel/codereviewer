        "retryBackoffMs": {
          "default": 500,
          "type": "integer",
          "minimum": 0,
          "maximum": 60000
        },
        "retryMaxDelayMs": {
          "default": 30000,
          "type": "integer",
          "minimum": 0,
          "maximum": 600000
