        "inlineSeverityThreshold": {
          "default": "high",
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ]
        },
        "maxCostUsd": {
          "type": "number",
          "minimum": 0
