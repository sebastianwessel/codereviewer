      "default": {
        "mode": "local",
        "depth": "balanced",
        "baseRef": "main",
        "headRef": "HEAD",
        "maxConcurrentTasks": 4,
        "maxFiles": 500,
        "maxFileBytes": 500000,
        "inlineSeverityThreshold": "high"
