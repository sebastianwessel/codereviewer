            "**/npm-shrinkwrap.json",
            "**/composer.lock",
            "**/Gemfile.lock",
            "**/poetry.lock",
            "**/Cargo.lock",
            "**/go.sum",
            "**/*.min.js",
            "**/*.min.css",
            "**/*.map",
            "**/*.snap"
